{
  "tasks": {
    "play:local": "deno run --watch -A main_local.ts",
    "play:remote": "deno run --watch -A main_remote.ts",
    "test": "deno test --allow-read --allow-net --allow-env",
    "fmt": "deno fmt --options-single-quote --options-line-width=120 --check",
    "fmt:fix": "deno fmt --options-single-quote --options-line-width=120"
  },
  "lock": false
}
